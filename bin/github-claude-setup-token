#!/usr/bin/env zsh
set -euo pipefail

# トークンを取得します。
# 自動的にwebブラウザが開かれるので承認してください。
# 制御文字を取り除いたあと、トークンの形式にマッチする文字列を抽出します。
# 2つ以上の改行は別の行としますが、1つの改行は折り返しとして扱います。
# claude側は対話的なターミナルを想定しているため、表示が重複します。
# よってuniqで重複を取り除いています。
token=$(claude --bare setup-token \
          | sed 's/\[[0-9;]*[a-zA-Z]//g' \
          | awk 'BEGIN{RS=""; ORS="\n"} {gsub(/\n/,""); print}' \
          | grep -oE 'sk-ant-oat[A-Za-z0-9_-]+' \
          | uniq)

# トークンが取得できなかった場合はエラーを出力して終了します。
if [[ -z "$token" ]]; then
  echo "error: failed to extract token" >&2
  exit 1
fi

# GitHubの通常のActionsのSecretにトークンを設定します。
echo "$token" | gh secret set CLAUDE_CODE_OAUTH_TOKEN
# GitHubのDependabotのSecretにトークンを設定します。
# 通常のClaudeの`/install-github-app`ではDependabotのSecretは設定されません。
# 依存関係の更新でもレビューしてもらった方が便利です。
echo "$token" | gh secret set CLAUDE_CODE_OAUTH_TOKEN --app dependabot

# 正常に終了したら完了メッセージを出力します。
echo "done: CLAUDE_CODE_OAUTH_TOKEN set for both repository and dependabot"
